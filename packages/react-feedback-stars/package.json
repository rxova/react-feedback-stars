{
  "name": "react-feedback-stars",
  "version": "0.2.0",
  "type": "module",
  "description": "Any icon, any precision, accessible. A headless, zero-dependency React rating component.",
  "keywords": [
    "react",
    "rating",
    "star-rating",
    "stars",
    "review",
    "feedback",
    "headless",
    "accessible",
    "a11y",
    "emoji"
  ],
  "license": "MIT",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:browser": "vitest run --project browser",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "check:exports": "publint --strict && attw --pack .",
    "pack:smoke": "node ../../scripts/pack-smoke.mjs",
    "prepack": "pnpm build",
    "size": "size-limit",
    "react:min:install": "pnpm add -D react@18.3.1 react-dom@18.3.1 @types/react@18.3.27 @types/react-dom@18.3.7",
    "test:react-min": "pnpm run react:min:install && pnpm exec vitest run --project browser && pnpm run typecheck"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.5",
    "@size-limit/preset-small-lib": "^12.1.0",
    "@tanstack/react-form": "^1.33.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.4",
    "@vitest/browser": "^4.1.10",
    "@vitest/browser-playwright": "^4.1.10",
    "@vitest/coverage-v8": "^4.1.10",
    "final-form": "^5.0.1",
    "formik": "^2.4.9",
    "playwright": "^1.61.1",
    "publint": "^0.3.21",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "react-final-form": "^7.0.1",
    "react-hook-form": "^7.82.0",
    "size-limit": "^12.1.0",
    "tsdown": "^0.22.13",
    "typescript": "6.0.3",
    "vite": "^8.1.5",
    "vitest": "^4.1.10",
    "vitest-browser-react": "^2.2.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rxova/react-feedback-stars.git",
    "directory": "packages/react-feedback-stars"
  },
  "bugs": {
    "url": "https://github.com/rxova/react-feedback-stars/issues"
  },
  "homepage": "https://rxova.github.io/react-feedback-stars/"
}
