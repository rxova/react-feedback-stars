{
  "name": "react-feedback-stars-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Monorepo for react-feedback-stars: the published package, the playground, and the docs site.",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck && tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "pnpm -r test",
    "test:unit": "pnpm --filter react-feedback-stars test:unit",
    "test:browser": "pnpm --filter react-feedback-stars test:browser",
    "test:coverage": "pnpm --filter react-feedback-stars test:coverage",
    "test:react-min": "pnpm --filter react-feedback-stars test:react-min",
    "size": "pnpm -r size",
    "check:exports": "pnpm --filter react-feedback-stars check:exports",
    "pack:smoke": "pnpm --filter react-feedback-stars pack:smoke",
    "audit:check": "pnpm audit --audit-level=high",
    "dedupe:check": "pnpm dedupe --check",
    "check:browsers": "node scripts/check-browsers.mjs",
    "capture": "node scripts/capture-examples.mjs",
    "verify": "node scripts/verify.mjs",
    "dev": "pnpm --filter @react-feedback-stars/playground dev",
    "playground:build": "pnpm --filter @react-feedback-stars/playground build",
    "playground:preview": "pnpm --filter @react-feedback-stars/playground preview",
    "docs": "pnpm --filter @react-feedback-stars/docs start",
    "docs:build": "pnpm --filter @react-feedback-stars/docs build",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:install": "playwright install --with-deps chromium firefox webkit",
    "release": "pnpm -r build && changeset publish",
    "prepare": "husky"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.1",
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "1.61.1",
    "@types/node": "^26.1.1",
    "axe-core": "^4.12.1",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "gifenc": "^1.0.3",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.1.1",
    "playwright": "^1.61.1",
    "pngjs": "^7.0.0",
    "prettier": "^3.9.6",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.65.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,css}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "packageManager": "pnpm@11.9.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rxova/react-feedback-stars.git"
  },
  "bugs": {
    "url": "https://github.com/rxova/react-feedback-stars/issues"
  },
  "homepage": "https://github.com/rxova/react-feedback-stars#readme"
}
