{
  "name": "react-feedback-stars",
  "version": "0.1.0",
  "type": "module",
  "description": "Headless, zero-dependency React rating component. Any icon, any precision, accessible.",
  "keywords": [
    "react",
    "rating",
    "star-rating",
    "stars",
    "review",
    "feedback",
    "headless",
    "accessible",
    "a11y",
    "emoji"
  ],
  "license": "MIT",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:browser": "vitest run --project browser",
    "test:watch": "vitest",
    "check:exports": "publint --strict && attw --pack .",
    "prepack": "pnpm build",
    "prepare": "husky",
    "release": "pnpm build && changeset publish",
    "size": "size-limit",
    "test:coverage": "vitest run --coverage",
    "audit:check": "pnpm audit --audit-level=high",
    "dedupe:check": "pnpm dedupe --check",
    "pack:smoke": "node scripts/pack-smoke.mjs",
    "verify": "node scripts/verify.mjs",
    "dev": "vite --config playground/vite.config.ts",
    "playground:build": "vite build --config playground/vite.config.ts",
    "playground:preview": "vite preview --config playground/vite.config.ts",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "react:min:install": "pnpm add -D react@18.3.1 react-dom@18.3.1 @types/react@18.3.27 @types/react-dom@18.3.7",
    "test:react-min": "pnpm run react:min:install && pnpm exec vitest run --project browser && pnpm run typecheck",
    "e2e:install": "playwright install --with-deps chromium firefox webkit",
    "check:browsers": "node scripts/check-browsers.mjs"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.5",
    "@axe-core/playwright": "^4.12.1",
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.1",
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "1.61.1",
    "@size-limit/preset-small-lib": "^12.1.0",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.4",
    "@vitest/browser": "^4.1.10",
    "@vitest/browser-playwright": "^4.1.10",
    "@vitest/coverage-v8": "^4.1.10",
    "axe-core": "^4.12.1",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "final-form": "^5.0.1",
    "formik": "^2.4.9",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.1.1",
    "playwright": "^1.61.1",
    "prettier": "^3.9.6",
    "publint": "^0.3.21",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "react-final-form": "^7.0.1",
    "react-hook-form": "^7.82.0",
    "size-limit": "^12.1.0",
    "tsdown": "^0.22.13",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.65.0",
    "vite": "^8.1.5",
    "vitest": "^4.1.10",
    "vitest-browser-react": "^2.2.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,css}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "packageManager": "pnpm@11.9.0",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rxova/react-feedback-stars.git"
  },
  "bugs": {
    "url": "https://github.com/rxova/react-feedback-stars/issues"
  },
  "homepage": "https://github.com/rxova/react-feedback-stars#readme"
}
